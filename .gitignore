# ── Python ─────────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.ipynb_checkpoints/

# ── Environments ───────────────────────────────────────
.venv/
venv/
env/
.python-version
.env
.env.local

# ── ML / RL artifacts (kept out of git; live in WSL ext4) ─
*.pt
*.pth
*.ckpt
*.safetensors
*.bin
*.h5
*.onnx

# ── Audio / datasets ───────────────────────────────────
*.wav
*.mp3
*.flac
*.ogg
*.m4a
data/
datasets/
checkpoints/

# ── Experiment tracking / outputs ──────────────────────
mlruns/
mlartifacts/
outputs/
runs/
logs/
wandb/
.hydra/
lightning_logs/
hf-cache/

# ── Each work is its own repo (not tracked by the umbrella) ─
projects/*/

# ── OS / editor ────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
.codex/

# ── Wiki working clone (scripts/wiki-sync.sh) — transient, never tracked ─
.wiki-tmp/

# ── Data root: never commit models/datasets (≈281 GB; fetch via scripts/data/) ─
# This is the single most important guard: speechrl-data/ holds all model weights,
# datasets, reference repos and logs. It must never reach GitHub.
speechrl-data/

# ── Extra weight / archive / array formats (defense-in-depth, anywhere in tree) ─
*.gguf
*.npy
*.npz
*.arrow
*.parquet
*.tar
*.tar.gz
*.tgz
*.zip
*.7z

# ── Scratch, probes, root-level logs ───────────────────
*.log
.tmp_*
hf_probe*
# Large local AI reference dump — not part of the repo
CLAUDE-FABLE-5.md

# ── Re-include tracked download scripts ────────────────
# The broad `data/` rule above also matches scripts/data/, which holds CODE
# (download scripts), not datasets. Re-include that one path.
!scripts/data/
!scripts/data/**

# ── Re-include the speechrl_common.data source module ──
# The broad `data/` rule also matched this CODE dir, silently dropping the
# dataset-registry module from git. Keep the source; still ignore its pycache.
!common/src/speechrl_common/data/
!common/src/speechrl_common/data/**
common/src/speechrl_common/data/__pycache__/
